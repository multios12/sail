{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Debug",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/api/cmd/sail",
      "cwd": "${workspaceFolder}",
      "args": [
        "-d",
        "${workspaceFolder}/data",
        "-p",
        ":3001",
        "-w",
        "H0812109"
      ]
    },
    {
      "name": "Open Front in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/front",
      "preLaunchTask": "front: dev",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "vite://*": "${workspaceFolder}/front/*",
        "/@fs/*": "*",
        "src/*": "${workspaceFolder}/front/src/*",
        "/*": "${workspaceFolder}/front/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Dev: Front + API",
      "configurations": [
        "API Debug",
        "Open Front in Edge"
      ],
      "stopAll": true
    }
  ]
}
